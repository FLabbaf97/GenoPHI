# Include documentation and license files
include README.md
include LICENSE

# Include any data files if needed in the future
# recursive-include genophi/data *

# Exclude development and build files
exclude .gitignore
exclude manuscript_scripts/results_analysis/public_data_modeling_analysis.ipynb
recursive-exclude * __pycache__
recursive-exclude * *.py[cod]
recursive-exclude * *.so
recursive-exclude * .DS_Store
